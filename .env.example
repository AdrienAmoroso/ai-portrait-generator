# Required for Gemini backend — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Backend: "gemini" or "comfyui"
BACKEND=gemini

# ComfyUI settings (only needed if BACKEND=comfyui)
# COMFYUI_URL=http://127.0.0.1:8188
# COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
# COMFYUI_CONTROLNET_MODEL=control-lora-openposeXL2-rank256.safetensors
# CONTROLNET_STRENGTH=0.7

# Generation parameters
# IMAGE_WIDTH=1024
# IMAGE_HEIGHT=1024
# GENERATION_STEPS=25
# CFG_SCALE=7.0
# DELAY_BETWEEN_REQUESTS=2

# QA checks
# QA_ENABLED=true
# QA_MAX_RETRIES=3

# Background removal
# BG_REMOVAL_ENABLED=true
